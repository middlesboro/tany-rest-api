# STAGE 1: Build (Využitie 16 GB RAM a 4 vCPU)
FROM ghcr.io/graalvm/native-image-community:21-ol9 AS builder

WORKDIR /build

# 1. Optimalizácia: Skopírujeme len wrapper a pom.xml pre kešovanie závislostí
COPY .mvn/ .mvn
COPY mvnw pom.xml ./

# 2. Optimalizácia: Paralelné stiahnutie závislostí (-T 1C využije všetky jadrá)
# Táto vrstva sa znova buildne, len ak zmeníš pom.xml
RUN ./mvnw -T 1C dependency:go-offline -B

# 3. Skopírujeme zdrojové kódy
COPY src ./src

# 4. Optimalizácia GraalVM buildu:
# -Pnative: aktivuje Spring Boot Native profil
# -T 1C: paralelné spracovanie Mavenu
# -DskipTests: preskočí testy pre rýchlejší build
# -J-Xmx12g: povie GraalVM, že môže použiť až 12 GB RAM z tvojich 16 GB
RUN ./mvnw -Pnative native:compile -DskipTests -T 1C \
    -Dmaven.javadoc.skip=true \
    -Dspring-boot.repackage.skip=true \
    -Dnative.buildArgs="-J-Xmx12g --parallelism=4"

# STAGE 2: Runtime (Maximálna bezpečnosť cez Distroless)
# Neobsahuje shell, ls, cd, curl - len tvoju binárku a SSL certifikáty
FROM gcr.io/distroless/base-debian12
WORKDIR /app

# Skopírujeme skompilovanú binárku (nahraď názov podľa tvojho artifactId)
# Tip: Ak nevieš názov, v target/ je to súbor bez prípony .jar
COPY --from=builder /build/target/tany-rest-api .

# Spúšťame v "exec forme" (pole), pretože v obraze nie je /bin/sh
ENTRYPOINT ["./tany-rest-api"]
